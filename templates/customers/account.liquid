<!-- /templates/customers/account.liquid -->

<div class="color-{{ settings.customer_color_scheme }} color-background color-text min-h-screen py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">

    {%- comment -%} Header {%- endcomment -%}
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-foreground mb-2">
        {{ 'customer.account.page_title' | t }}
      </h1>
      <p class="text-sm text-foreground/60">
        {{ 'customer.account.greeting' | t: name: customer.first_name }}
      </p>
    </div>

    {%- comment -%} Main Grid {%- endcomment -%}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

      {%- comment -%} Welcome Card {%- endcomment -%}
      <div class="bg-background rounded-lg shadow-lg p-6 lg:col-span-2">
        <div class="flex items-start justify-between mb-6">
          <div>
            <h2 class="text-xl font-bold text-foreground mb-1">
              {{ 'customer.account.welcome_back' | t }}
            </h2>
            <p class="text-sm text-foreground/60">
              {{ customer.email }}
            </p>
          </div>
          <a
            href="{{ routes.account_logout_url }}"
            class="text-sm text-foreground/60 hover:text-foreground transition-colors inline-flex items-center"
          >
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            {{ 'customer.account.logout' | t }}
          </a>
        </div>

        {%- comment -%} Quick Stats {%- endcomment -%}
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <div class="bg-foreground/5 rounded-lg p-4">
            <p class="text-xs text-foreground/60 mb-1">{{ 'customer.account.total_orders' | t }}</p>
            <p class="text-2xl font-bold text-foreground">{{ customer.orders_count }}</p>
          </div>
          <div class="bg-foreground/5 rounded-lg p-4">
            <p class="text-xs text-foreground/60 mb-1">{{ 'customer.account.saved_addresses' | t }}</p>
            <p class="text-2xl font-bold text-foreground">{{ customer.addresses_count }}</p>
          </div>
          <div class="bg-foreground/5 rounded-lg p-4 sm:col-span-1 col-span-2">
            <p class="text-xs text-foreground/60 mb-1">{{ 'customer.account.customer_since' | t }}</p>
            <p class="text-lg font-bold text-foreground">{{ customer.created_at | date: "%Y" }}</p>
          </div>
        </div>
      </div>

      {%- comment -%} Quick Actions Card {%- endcomment -%}
      <div class="bg-background rounded-lg shadow-lg p-6">
        <h3 class="text-lg font-bold text-foreground mb-4">{{ 'customer.account.quick_actions' | t }}</h3>
        <div class="space-y-3">
          <a
            href="{{ routes.account_addresses_url }}"
            class="flex items-center justify-between p-3 bg-foreground/5 rounded-lg hover:bg-foreground/5 transition-colors group"
          >
            <div class="flex items-center">
              <svg class="w-5 h-5 text-foreground/60 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-sm font-medium text-foreground">{{ 'customer.account.manage_addresses' | t }}</span>
            </div>
            <svg class="w-4 h-4 text-foreground/40 group-hover:text-foreground/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>

          <a
            href="{{ routes.root_url }}"
            class="flex items-center justify-between p-3 bg-foreground/5 rounded-lg hover:bg-foreground/5 transition-colors group"
          >
            <div class="flex items-center">
              <svg class="w-5 h-5 text-foreground/60 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              <span class="text-sm font-medium text-foreground">{{ 'customer.account.continue_shopping' | t }}</span>
            </div>
            <svg class="w-4 h-4 text-foreground/40 group-hover:text-foreground/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    {%- comment -%} Default Address {%- endcomment -%}
    {%- if customer.default_address -%}
      <div class="bg-background rounded-lg shadow-lg p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-foreground">{{ 'customer.account.default_address' | t }}</h3>
          <a
            href="{{ routes.account_addresses_url }}"
            class="text-sm text-foreground hover:text-foreground/70 font-medium transition-colors"
          >
            {{ 'customer.account.edit' | t }}
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex items-start">
            <svg class="w-5 h-5 text-foreground/40 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div class="text-sm text-foreground/70">
              <p class="font-medium text-foreground mb-1">
                {{ customer.default_address.first_name }} {{ customer.default_address.last_name }}
              </p>
              <p>{{ customer.default_address.address1 }}</p>
              {%- if customer.default_address.address2 != blank -%}
                <p>{{ customer.default_address.address2 }}</p>
              {%- endif -%}
              <p>
                {{ customer.default_address.city }}{%- if customer.default_address.province_code -%}, {{ customer.default_address.province_code }}{%- endif -%}
              </p>
              <p>{{ customer.default_address.zip }}</p>
              <p>{{ customer.default_address.country }}</p>
            </div>
          </div>
          {%- if customer.default_address.phone -%}
            <div class="flex items-start">
              <svg class="w-5 h-5 text-foreground/40 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <div class="text-sm text-foreground/70">
                <p class="font-medium text-foreground mb-1">{{ 'customer.account.phone' | t }}</p>
                <p>{{ customer.default_address.phone }}</p>
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Orders Section {%- endcomment -%}
    <div class="bg-background rounded-lg shadow-lg p-6">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-bold text-foreground">{{ 'customer.account.recent_orders' | t }}</h3>
        {%- if customer.orders_count > 5 -%}
          <p class="text-sm text-foreground/60">
            {{ 'customer.account.showing_orders' | t: shown: 5, total: customer.orders_count }}
          </p>
        {%- endif -%}
      </div>

      {%- paginate customer.orders by 5 -%}
        {%- if customer.orders.size > 0 -%}
          <div class="space-y-4">
            {%- for order in customer.orders -%}
              <div class="border border-border rounded-lg p-4 border-border transition-colors">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-3">
                  <div class="mb-2 sm:mb-0">
                    <a
                      href="{{ order.customer_url }}"
                      class="text-sm font-bold text-foreground hover:text-foreground/70 transition-colors"
                    >
                      {{ 'customer.orders.order_label' | t }} #{{ order.name }}
                    </a>
                    <p class="text-xs text-foreground/60 mt-1">
                      {{ order.created_at | date: "%d/%m/%Y às %H:%M" }}
                    </p>
                  </div>
                  <div class="flex items-center space-x-3">
                    {%- case order.financial_status -%}
                      {%- when 'pending' -%}
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium color-warning-bg color-warning">
                          {{ 'customer.orders.status.payment_pending' | t }}
                        </span>
                      {%- when 'authorized' or 'paid' -%}
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium color-success-bg color-success">
                          {{ 'customer.orders.status.paid' | t }}
                        </span>
                      {%- when 'refunded' -%}
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-foreground/5 text-foreground">
                          {{ 'customer.orders.status.refunded' | t }}
                        </span>
                      {%- else -%}
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-foreground/5 text-foreground">
                          {{ order.financial_status }}
                        </span>
                    {%- endcase -%}

                    {%- case order.fulfillment_status -%}
                      {%- when 'fulfilled' -%}
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                          {{ 'customer.orders.status.fulfilled' | t }}
                        </span>
                      {%- when 'partial' -%}
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium color-warning-bg color-warning">
                          {{ 'customer.orders.status.partial' | t }}
                        </span>
                      {%- when 'unfulfilled' -%}
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-foreground/5 text-foreground">
                          {{ 'customer.orders.status.unfulfilled' | t }}
                        </span>
                      {%- else -%}
                        {%- if order.fulfillment_status -%}
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-foreground/5 text-foreground">
                            {{ order.fulfillment_status }}
                          </span>
                        {%- endif -%}
                    {%- endcase -%}
                  </div>
                </div>

                <div class="flex items-center justify-between pt-3 border-t border-border">
                  <div>
                    <p class="text-xs text-foreground/60 mb-1">
                      {{ 'customer.orders.items_count' | t: count: order.line_items.size }}
                    </p>
                    <p class="text-sm font-bold text-foreground">
                      {{ order.total_price | money }}
                    </p>
                  </div>
                  <a
                    href="{{ order.customer_url }}"
                    class="inline-flex items-center px-4 py-2 border border-border rounded-lg text-sm font-medium text-foreground bg-background hover:bg-foreground/5 transition-colors"
                  >
                    {{ 'customer.orders.view_details' | t }}
                    <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </div>
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <div class="mt-6 flex items-center justify-center">
              {%- render 'pagination', paginate: paginate -%}
            </div>
          {%- endif -%}

        {%- else -%}
          {%- comment -%} Empty State {%- endcomment -%}
          <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-foreground/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-foreground">{{ 'customer.orders.empty_title' | t }}</h3>
            <p class="mt-1 text-sm text-foreground/50">
              {{ 'customer.orders.empty_text' | t }}
            </p>
            <div class="mt-6">
              <a
                href="{{ routes.all_products_collection_url }}"
                class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-lg text-background bg-foreground hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-foreground transition-colors"
              >
                <svg class="mr-2 -ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                </svg>
                {{ 'customer.orders.explore_products' | t }}
              </a>
            </div>
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>

  </div>
</div>
