{%- comment -%}
  Card individual de depoimento (registro editorial minimalista).

  Parâmetros:
  - block: bloco com configurações (obrigatório)
  - card_color_scheme: esquema de cores do card (fallback scheme-2)
{%- endcomment -%}

{%- liquid
  assign customer_image = block.settings.customer_image
  assign customer_name = block.settings.customer_name
  assign customer_location = block.settings.customer_location
  assign rating = block.settings.rating | default: 5
  assign testimonial_text = block.settings.testimonial_text
  assign product_purchased = block.settings.product_purchased

  assign scheme = card_color_scheme | default: 'scheme-2'
-%}

<div class="color-{{ scheme }} color-background color-text rounded-theme p-6 md:p-8 h-full flex flex-col transition-shadow duration-300 hover:shadow-lg">

  {%- comment -%} Rating {%- endcomment -%}
  <div class="flex gap-1 mb-5">
    {%- for i in (1..5) -%}
      <svg class="w-4 h-4 {% if i <= rating %}color-warning{% else %}opacity-25{% endif %}" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {%- endfor -%}
  </div>

  {%- comment -%} Depoimento (herói do card) {%- endcomment -%}
  <p class="flex-1 text-sm md:text-base leading-relaxed color-text mb-6">
    "{{ testimonial_text }}"
  </p>

  {%- comment -%} Cliente {%- endcomment -%}
  <div class="pt-5 color-border border-t flex items-center gap-3">
    <div class="flex-shrink-0">
      {% if customer_image != blank %}
        <img
          src="{{ customer_image | image_url: width: 120 }}"
          alt="{{ customer_name | escape }}"
          class="w-11 h-11 rounded-full object-cover"
          loading="lazy"
          decoding="async"
        >
      {% else %}
        <div class="w-11 h-11 rounded-full color-border border flex items-center justify-center">
          <span class="text-base font-medium color-text">{{ customer_name | slice: 0 | upcase }}</span>
        </div>
      {% endif %}
    </div>
    <div class="min-w-0">
      <p class="text-sm font-medium truncate color-text">{{ customer_name }}</p>
      {% if customer_location != blank %}
        <p class="text-xs color-text-muted truncate">{{ customer_location }}</p>
      {% endif %}
    </div>
  </div>

  {%- comment -%} Verificação + produto (linha sutil) {%- endcomment -%}
  <p class="mt-3 text-xs color-text-muted flex items-center gap-1.5">
    {% render 'trust-badge-icon', icon: 'check-circle', size: 13 %}
    <span class="truncate">
      {{- 'testimonials.verified_purchase' | t -}}
      {%- if product_purchased != blank %} · {{ product_purchased }}{% endif -%}
    </span>
  </p>

</div>
