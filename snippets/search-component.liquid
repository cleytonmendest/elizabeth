{% if flex == blank %}
  {% assign flex = 1 %}
{% endif %}

<div
  class="items-center max-lg:!flex-1 lg:flex {% if showMobile %} flex {% else %} hidden {% endif %}"
  style="flex: {{ flex }};"
>
  <search-component
    class="w-full relative flex justify-center group group-[.is-searching]"
    data-no-results-template="{{ 'general.search.no_results' | t: terms: '@@QUERY@@' | escape }}"
    data-sold-out-label="{{ 'product.general.sold_out' | t | escape }}"
  >
    <form action="{{ routes.search_url }}" method="get" role="search">
      <div class="flex rounded-full transition-all duration-300 py-2 px-4 bg-foreground/5 lg:bg-foreground/5 h-10 lg:group-hover:bg-foreground/10 relative">
        <input
          class="
            w-full bg-transparent focus:outline-none focus:ring-0 focus:border-transparent
            focus-visible:outline-none focus-visible:ring-0 placeholder:font-light placeholder:text-sm placeholder:text-foreground/50
          "
          id="Search-In-Template"
          type="text"
          autocomplete="off"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'general.search.placeholder' | t }}"
        >
        <button
          type="submit"
          class="color-text"
          aria-label="{{ 'general.search.submit' | t }}"
        >
          {% render 'icon-search', size: 25 %}
        </button>
      </div>
    </form>
    <div
      id="search-component-dropdown"
      tabindex="-1"
      class="search-results absolute w-full sm:w-[150%] max-w-[90vw] bg-background top-full mt-2 rounded-theme shadow-lg border border-border hidden overflow-hidden z-50"
    >
      {%- comment -%} Loading State {%- endcomment -%}
      <div class="search-loading hidden">
        <div class="flex items-center justify-center p-4">
          <svg class="animate-spin h-4 w-4 text-foreground/40" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="ml-2.5 text-sm text-foreground/60">{{ 'general.search.searching' | t }}</span>
        </div>
      </div>

      {%- comment -%} Template para Produtos {%- endcomment -%}
      <template id="search-result-template">
        <a href="#" class="search-result-item flex items-center gap-3 p-3 hover:bg-foreground/5 transition-colors border-b border-border last:border-b-0">
          <div class="flex-shrink-0 w-16 h-16 bg-foreground/10 rounded-theme overflow-hidden">
            {%- comment -%} src/alt preenchidos em runtime pelo search-component.js (CDN da Shopify) {%- endcomment -%}
            {% # theme-check-disable RemoteAsset %}
            <img src="" alt="" width="64" height="64" class="search-result-image w-full h-full object-cover">
            {% # theme-check-enable RemoteAsset %}
          </div>
          <div class="flex-1 min-w-0">
            <p class="search-result-title font-light text-sm text-foreground line-clamp-2"></p>
            <div class="flex items-center gap-2 mt-1">
              <span class="search-result-price text-sm font-medium text-foreground"></span>
              <span class="search-result-badge hidden text-xs px-2 py-0.5 rounded-theme font-medium"></span>
            </div>
          </div>
        </a>
      </template>

      {%- comment -%} Template para Coleções {%- endcomment -%}
      <template id="collection-result-template">
        <a href="#" class="collection-result-item flex items-center gap-3 p-3 hover:bg-foreground/5 transition-colors border-b border-border">
          <div class="flex-shrink-0 w-10 flex justify-center">
            <svg class="w-5 h-5 text-foreground/40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <div class="flex-1">
            <p class="collection-result-title font-light text-sm text-foreground"></p>
            <p class="text-xs text-foreground/50">{{ 'collection.general.label' | t }}</p>
          </div>
        </a>
      </template>

      {%- comment -%} Container de Resultados {%- endcomment -%}
      <div class="search-results-content max-h-[60vh] overflow-y-auto"></div>

      {%- comment -%} Footer com "Ver todos" {%- endcomment -%}
      <div class="search-footer hidden border-t border-border">
        <a href="#" class="block p-3 text-center text-sm font-light text-foreground/70 hover:bg-foreground/5 transition-colors">
          {{ 'general.search.view_all_results' | t }}
        </a>
      </div>
    </div>
  </search-component>
</div>
