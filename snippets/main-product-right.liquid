{% liquid
  assign qtd_side_buy = false

  for block in blocks
    if block.type == 'quantity_selector'
      assign qtd_side_buy = block.settings.sideToBuyButton
    endif
  endfor
%}

<div class="lg:sticky top-24 w-full flex flex-col gap-5">
  {% for block in blocks %}
    {% case block.type %}
      {%- when '@app' -%}
        {% render block %}
      {%- when 'text' -%}
        <p
          class="product__text inline-richtext{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
          {{ block.shopify_attributes }}
        >
          {{- block.settings.text -}}
        </p>

      {%- when 'quantity_selector' -%}
        {% if qtd_side_buy != true %}
          {%- render 'quantity-selector' -%}
        {% endif %}

      {%- when 'sku' -%}
        <div>SKU não implementado</div>

      {%- when 'title' -%}
        <div class="product__title" {{ block.shopify_attributes }}>
          {%- if product.type != blank -%}
            <p class="text-xs uppercase tracking-[0.18em] text-foreground/50 mb-2.5">{{ product.type }}</p>
          {%- endif -%}
          <h1 class="text-4xl font-light tracking-tight leading-tight">{{ product.title | escape }}</h1>
        </div>

      {%- when 'price' -%}
        <div role="status" {{ block.shopify_attributes }}>
          {%- render 'price-v2', product: product, use_variant: true, pdp: true, show_installments: true -%}
        </div>

      {%- when 'inventory' -%}
        {%- render 'inventory-status', block: block, product: product -%}

      {%- when 'variant_picker' -%}
        {% render 'product-variant-picker', product: product, block: block %}

      {%- when 'description' -%}
        {%- if product.description != blank -%}
          <div>
            {% if block.settings.show_title == true %}
              <h2 class="text-xs uppercase tracking-[0.18em] text-foreground/50 mb-2">{{ block.settings.title_text | default: 'Descrição' }}</h2>
            {% endif %}
            <div class="text-sm leading-relaxed text-foreground/80" {{ block.shopify_attributes }}>
              {{ product.description }}
            </div>
          </div>
        {%- endif -%}

      {%- when 'assurances' -%}
        {%- render 'product-assurances', block: block -%}

      {%- when 'collapsible_tab' -%}
        <div class="product__accordion accordion quick-add-hidden border-t border-border last:border-b" {{ block.shopify_attributes }}>
          {% if block.settings.content != blank or block.settings.page.content != blank %}
            <details id="Details-{{ block.id }}-{{ section.id }}" class="group">
              <summary class="flex cursor-pointer justify-between items-center py-4 list-none">
                <h2 class="text-sm tracking-wide">
                  {{ block.settings.heading | default: block.settings.page.title | escape }}
                </h2>
                {% render 'icon-angle-down',
                  size: 16,
                  class: 'text-foreground/50 transition-transform duration-300 group-open:rotate-180'
                %}
              </summary>
              <div class="text-sm leading-relaxed text-foreground/70 pb-4" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                {{ block.settings.content }}
                {{ block.settings.page.content }}
              </div>
            </details>
          {% endif %}
        </div>
      {%- when 'payment_icons' -%}
        {%- render 'payment-icons', block: block -%}

      {%- when 'buy_button' -%}
        {%- render 'add-to-cart', product: product, hasQtd: qtd_side_buy, block: block -%}
    {% endcase %}
  {% endfor %}
</div>
