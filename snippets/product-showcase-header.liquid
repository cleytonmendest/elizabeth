{%- comment -%}
  product-showcase-header — título + subtítulo (alinhados à esquerda ou centralizados)
  e, no modo slider, as setas de navegação. Compartilhado pelas seções que usam o
  componente product-showcase.

  Params: heading, subtitle, alignment ('left'|'center'), show_nav (bool), section_id
{%- endcomment -%}

{%- liquid
  assign alignment = alignment | default: 'center'
-%}

{%- if heading != blank or subtitle != blank or show_nav -%}
  <div class="mb-6 lg:mb-8 flex gap-4 {% if alignment == 'center' %}flex-col items-center text-center{% else %}items-end justify-between{% endif %}">
    <div class="{% unless alignment == 'left' %}max-w-2xl{% endunless %}">
      {%- if heading != blank -%}
        <h2 class="text-2xl md:text-3xl font-light tracking-tight text-foreground">{{ heading }}</h2>
      {%- endif -%}
      {%- if subtitle != blank -%}
        <div class="text-sm text-foreground/70 mt-1">{{ subtitle }}</div>
      {%- endif -%}
    </div>
    {%- if show_nav -%}
      <div class="flex gap-2 shrink-0">
        <button
          type="button"
          onclick="sliderPrev('{{ section_id }}')"
          aria-label="{{ 'sections.slider.previous' | t }}"
          class="w-9 h-9 flex items-center justify-center rounded-full border border-border text-foreground hover:bg-foreground hover:text-background transition-colors"
        >
          {% render 'icon-angle-left', size: 18 %}
        </button>
        <button
          type="button"
          onclick="sliderNext('{{ section_id }}')"
          aria-label="{{ 'sections.slider.next' | t }}"
          class="w-9 h-9 flex items-center justify-center rounded-full border border-border text-foreground hover:bg-foreground hover:text-background transition-colors"
        >
          {% render 'icon-angle-right', size: 18 %}
        </button>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}
