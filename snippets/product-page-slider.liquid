{% if product_ref != blank %}
  {% assign product = product_ref %}
{% endif %}

{%- comment -%}
  Navegação por breakpoint:
  - Mobile: dots minimalistas + contador "X / N" (setas ocultas)
  - Desktop: setas ‹ › (dots/contador ocultos) — comportamento original preservado
{%- endcomment -%}
<style>
  my-slider.pdp-gallery { display: block; position: relative; }
  my-slider.pdp-gallery .swiper-pagination {
    position: absolute; bottom: 12px; left: 0; right: 0;
    display: flex; justify-content: center; align-items: center; gap: 6px; z-index: 10;
  }
  my-slider.pdp-gallery .swiper-pagination-bullet {
    width: 6px; height: 6px; margin: 0 !important; border-radius: 9999px;
    background: rgb(var(--color-foreground)); opacity: .3; transition: all .25s ease;
  }
  my-slider.pdp-gallery .swiper-pagination-bullet-active { opacity: 1; width: 18px; border-radius: 3px; }
  @media (min-width: 1024px) { my-slider.pdp-gallery .swiper-pagination { display: none; } }
</style>

<my-slider
  class="pdp-gallery block w-full"
  data-section-id="{{ section.id }}"
  data-loop="true"
  data-items="{{ product.images.size }}"
  data-qty-desk="{{ qtd }}"
  data-qty-tab="{{ qtd }}"
  data-qty-mob="1"
  data-autoplay="false"
  data-ap-time=""
  data-pause-hover=""
  data-dot="true"
>
  {% comment %} OBRIGATORIO TER A DIV "my-slider__container" PARA O CORRETO FUNCIONAMENTO {% endcomment %}
  <div class="my-slider__container overflow-hidden">
    {%- for image in product.images -%}
      <div class="carousel-item flex justify-center">
        <img
          class="w-full"
          src="{{ image | image_url }}"
          alt="{{ product.title }}"
          width="{{ image.width }}"
          height="{{ image.height }}"
        >
      </div>
    {% endfor %}
  </div>

  {%- comment -%} Contador de posição — somente mobile {%- endcomment -%}
  {%- if product.images.size > 1 -%}
    <div class="lg:hidden absolute top-3 right-3 z-10 bg-background/85 text-foreground text-xs tracking-wide rounded-theme px-2.5 py-1">
      <span class="index-active">1</span> / {{ product.images.size }}
    </div>
  {%- endif -%}
</my-slider>

{%- comment -%} Setas — somente desktop {%- endcomment -%}
<div class="hidden lg:flex absolute w-full justify-between top-[50%] z-10">
  <button
    onclick="sliderPrev('{{ section.id }}')"
    class="text-foreground"
  >
    {% render 'icon-short-arrow-left', size: 40 %}
  </button>
  <button
    onclick="sliderNext('{{ section.id }}')"
    class="text-foreground"
  >
    {% render 'icon-short-arrow-right', size: 40 %}
  </button>
</div>
