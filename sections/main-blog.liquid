{% paginate blog.articles by section.settings.posts_per_page %}

<div class="color-{{ section.settings.color_scheme }} color-background color-text">
<div class="page-width !py-8 !lg:py-12">
  {%- comment -%} Header do Blog {%- endcomment -%}
  <div class="mb-8 lg:mb-12">
    <h1 class="text-3xl lg:text-4xl font-light tracking-tight text-foreground mb-3">{{ blog.title }}</h1>
    {% if blog.description != blank %}
      <p class="text-sm text-foreground/55 max-w-2xl">{{ blog.description }}</p>
    {% endif %}
  </div>

  <div class="flex flex-col lg:flex-row-reverse gap-8">
    {%- comment -%} Main Content {%- endcomment -%}
    <div class="flex-1">
      {%- comment -%} Filtro por Tags {%- endcomment -%}
      {% if blog.all_tags.size > 0 and section.settings.show_tags %}
        <div class="mb-8 flex flex-wrap gap-2">
          <a
            href="{{ blog.url }}"
            class="px-5 py-2 rounded-full border text-xs uppercase tracking-[0.12em] transition-colors {% if current_tags.size == 0 %}bg-foreground text-background border-foreground{% else %}border-border text-foreground/70 hover:border-foreground/30{% endif %}"
          >
            {{ 'blog.general.all' | t }}
          </a>
          {% for tag in blog.all_tags limit: 10 %}
            <a
              href="{{ blog.url }}/tagged/{{ tag | handle }}"
              class="px-5 py-2 rounded-full border text-xs uppercase tracking-[0.12em] transition-colors {% if current_tags contains tag %}bg-foreground text-background border-foreground{% else %}border-border text-foreground/70 hover:border-foreground/30{% endif %}"
            >
              {{ tag }}
            </a>
          {% endfor %}
        </div>
      {% endif %}

      {%- comment -%} Grid de Artigos {%- endcomment -%}
      {% if blog.articles.size > 0 %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-{{ section.settings.grid_columns }} gap-6 lg:gap-8 mb-8">
          {% for article in blog.articles %}
            {% render 'card-article', article: article, show_excerpt: true, show_author: true, show_tags: section.settings.show_article_tags %}
          {% endfor %}
        </div>

        {%- comment -%} Paginação {%- endcomment -%}
        {% if paginate.pages > 1 %}
          {% render 'pagination', paginate: paginate %}
        {% endif %}
      {% else %}
        {%- comment -%} Empty State {%- endcomment -%}
        <div class="text-center py-20">
          <svg class="w-16 h-16 text-foreground/25 mx-auto mb-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
          </svg>
          <h2 class="text-2xl font-light tracking-tight text-foreground mb-2">{{ 'blog.general.no_posts' | t }}</h2>
          <p class="text-sm text-foreground/55 mb-8">{{ 'blog.general.no_posts_text' | t }}</p>
          <a href="{{ blog.url }}" class="inline-flex items-center bg-foreground text-background text-xs uppercase tracking-[0.18em] px-6 py-3.5 hover:opacity-90 transition-opacity">
            {{ 'blog.general.view_all' | t }}
          </a>
        </div>
      {% endif %}
    </div>

    {%- comment -%} Sidebar {%- endcomment -%}
    {% if section.settings.show_sidebar %}
      <aside class="w-full lg:w-80 space-y-8">
        {%- comment -%} Busca no Blog {%- endcomment -%}
        {% if section.settings.show_search %}
          <div class="border border-border rounded-theme p-6">
            <h3 class="text-xs uppercase tracking-[0.18em] text-foreground/60 mb-4">{{ 'blog.general.search_articles' | t }}</h3>
            <form action="{{ routes.search_url }}" method="get" role="search">
              <input type="hidden" name="type" value="article">
              <div class="relative">
                <input
                  type="search"
                  name="q"
                  placeholder="{{ 'blog.general.search_placeholder' | t }}"
                  class="w-full px-4 py-3 pr-12 border border-border rounded-theme focus:outline-none focus:ring-2 focus:ring-foreground/40 focus:border-transparent"
                >
                <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-foreground/50 hover:text-foreground transition-colors">
                  {% render 'icon-search', size: 20 %}
                </button>
              </div>
            </form>
          </div>
        {% endif %}

        {%- comment -%} Categorias/Tags {%- endcomment -%}
        {% if blog.all_tags.size > 0 and section.settings.show_sidebar_tags %}
          <div class="border border-border rounded-theme p-6">
            <h3 class="text-xs uppercase tracking-[0.18em] text-foreground/60 mb-4">{{ 'blog.general.categories' | t }}</h3>
            <div class="flex flex-wrap gap-2">
              {% for tag in blog.all_tags limit: 15 %}
                <a
                  href="{{ blog.url }}/tagged/{{ tag | handle }}"
                  class="px-4 py-1.5 text-xs uppercase tracking-[0.12em] text-foreground/70 border border-border rounded-full hover:border-foreground/30 transition-colors"
                >
                  {{ tag }}
                </a>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {%- comment -%} Artigos Recentes {%- endcomment -%}
        {% if section.settings.show_recent_posts %}
          <div class="border border-border rounded-theme p-6">
            <h3 class="text-xs uppercase tracking-[0.18em] text-foreground/60 mb-4">{{ 'blog.general.recent_posts' | t }}</h3>
            <div class="space-y-4">
              {% for article in blog.articles limit: 5 %}
                <a href="{{ article.url }}" class="block group">
                  <h4 class="text-sm font-normal text-foreground group-hover:text-foreground/60 line-clamp-2 mb-1 transition-colors">{{ article.title }}</h4>
                  <p class="text-xs text-foreground/50">{{ article.published_at | date: '%d/%m/%Y' }}</p>
                </a>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </aside>
    {% endif %}
  </div>
</div>
</div>

{% endpaginate %}

{% schema %}
{
  "name": "t:sections.main_blog.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.main_blog.settings.color_scheme.label",
      "default": "scheme-1",
      "info": "t:sections.main_blog.settings.color_scheme.info"
    },
    {
      "type": "header",
      "content": "t:sections.main_blog.settings.layout_header.content"
    },
    {
      "type": "range",
      "id": "posts_per_page",
      "min": 6,
      "max": 24,
      "step": 3,
      "label": "t:sections.main_blog.settings.posts_per_page.label",
      "default": 12
    },
    {
      "type": "range",
      "id": "grid_columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "t:sections.main_blog.settings.grid_columns.label",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "t:sections.main_blog.settings.show_tags.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_article_tags",
      "label": "t:sections.main_blog.settings.show_article_tags.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main_blog.settings.sidebar_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_sidebar",
      "label": "t:sections.main_blog.settings.show_sidebar.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:sections.main_blog.settings.show_search.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sidebar_tags",
      "label": "t:sections.main_blog.settings.show_sidebar_tags.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_recent_posts",
      "label": "t:sections.main_blog.settings.show_recent_posts.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.main_blog.presets.name"
    }
  ]
}
{% endschema %}
