{%- assign products_per_page = section.settings.products_per_page | default: 12 -%}
{%- assign articles_per_page = 6 -%}

<div class="page-width py-8">
  <div class="text-center mb-10 md:mb-12">
    <h1 class="text-3xl md:text-4xl font-light tracking-tight mb-5">
      {%- if search.performed -%}
        {{ 'general.search.results_for' | t: terms: search.terms }}
      {%- else -%}
        {{ 'general.search.title' | t }}
      {%- endif -%}
    </h1>

    {%- comment -%} Formulário de busca {%- endcomment -%}
    <form action="{{ routes.search_url }}" method="get" role="search" class="max-w-2xl mx-auto mb-6">
      <div class="relative">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'general.search.placeholder' | t }}"
          class="w-full px-4 py-3 pr-12 border border-border rounded-theme focus:outline-none focus:ring-2 focus:ring-foreground/40 text-base"
          required
        >
        <button
          type="submit"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-foreground/40 hover:text-foreground transition-colors"
          aria-label="{{ 'general.search.submit' | t }}"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>
      </div>
    </form>

    {%- if search.performed -%}
      <p class="text-sm text-foreground/55">
        {{ 'general.search.results_count' | t: count: search.results_count }}
      </p>
    {%- endif -%}
  </div>

  {%- if search.performed -%}
    {%- paginate search.results by products_per_page -%}
      {%- if search.results.size > 0 -%}
        {%- comment -%} Separar resultados por tipo {%- endcomment -%}
        {%- assign products = search.results | where: 'object_type', 'product' -%}
        {%- assign articles = search.results | where: 'object_type', 'article' -%}
        {%- assign pages = search.results | where: 'object_type', 'page' -%}

        {%- comment -%} Filtros de tipo {%- endcomment -%}
        {%- if section.settings.enable_type_filter -%}
          <div class="flex flex-wrap gap-2 justify-center mb-10">
            <button class="filter-button active px-5 py-2 border border-border rounded-full text-xs uppercase tracking-[0.12em] text-foreground/70 transition-colors" data-filter="all">
              {{ 'general.search.all' | t }} ({{ search.results_count }})
            </button>
            {%- if products.size > 0 -%}
              <button class="filter-button px-5 py-2 border border-border rounded-full text-xs uppercase tracking-[0.12em] text-foreground/70 transition-colors" data-filter="products">
                {{ 'general.search.products' | t }} ({{ products.size }})
              </button>
            {%- endif -%}
            {%- if articles.size > 0 -%}
              <button class="filter-button px-5 py-2 border border-border rounded-full text-xs uppercase tracking-[0.12em] text-foreground/70 transition-colors" data-filter="articles">
                {{ 'general.search.articles' | t }} ({{ articles.size }})
              </button>
            {%- endif -%}
            {%- if pages.size > 0 -%}
              <button class="filter-button px-5 py-2 border border-border rounded-full text-xs uppercase tracking-[0.12em] text-foreground/70 transition-colors" data-filter="pages">
                {{ 'general.search.pages' | t }} ({{ pages.size }})
              </button>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} PRODUTOS {%- endcomment -%}
        {%- if products.size > 0 -%}
          <div class="search-section" data-section="products">
            <h2 class="text-xl md:text-2xl font-light tracking-tight mb-6">{{ 'general.search.products' | t }}</h2>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-{{ section.settings.products_per_row }} gap-4 md:gap-6 mb-12">
              {%- for product in products -%}
                {%- render 'card-product-slider',
                  card_product: product,
                  show_second_image: false,
                  show_badges: true,
                  show_installments: false,
                  lazy_load: true,
                  remove_padding: true
                -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} ARTIGOS {%- endcomment -%}
        {%- if articles.size > 0 -%}
          <div class="search-section" data-section="articles">
            <h2 class="text-xl md:text-2xl font-light tracking-tight mb-6">{{ 'general.search.blog_articles' | t }}</h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
              {%- for article in articles limit: articles_per_page -%}
                <article class="group border border-border rounded-theme overflow-hidden transition-colors hover:border-foreground/30">
                  <a href="{{ article.url }}" class="block">
                    {%- if article.image -%}
                      <div class="aspect-[16/9] overflow-hidden bg-foreground/5">
                        <img
                          src="{{ article.image | image_url: width: 600 }}"
                          alt="{{ article.image.alt | escape }}"
                          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                          width="{{ article.image.width }}"
                          height="{{ article.image.height }}"
                          loading="lazy"
                          decoding="async"
                        >
                      </div>
                    {%- endif -%}
                    <div class="p-4">
                      <p class="text-xs uppercase tracking-[0.12em] text-foreground/50 mb-2">
                        {{ article.published_at | date: "%d/%m/%Y" }}
                      </p>
                      <h3 class="text-base font-normal mb-2 line-clamp-2">
                        {{ article.title }}
                      </h3>
                      {%- if article.excerpt != blank -%}
                        <p class="text-sm text-foreground/60 line-clamp-3">
                          {{ article.excerpt | strip_html }}
                        </p>
                      {%- endif -%}
                    </div>
                  </a>
                </article>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} PÁGINAS {%- endcomment -%}
        {%- if pages.size > 0 -%}
          <div class="search-section" data-section="pages">
            <h2 class="text-xl md:text-2xl font-light tracking-tight mb-6">{{ 'general.search.pages' | t }}</h2>
            <div class="space-y-4 mb-12">
              {%- for page in pages -%}
                <div class="border border-border rounded-theme p-4 transition-colors hover:border-foreground/30">
                  <a href="{{ page.url }}" class="block">
                    <h3 class="text-base font-normal mb-2">{{ page.title }}</h3>
                    {%- if page.content != blank -%}
                      <p class="text-sm text-foreground/60 line-clamp-2">
                        {{ page.content | strip_html | truncatewords: 30 }}
                      </p>
                    {%- endif -%}
                  </a>
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          <div class="mt-12">
            {%- render 'pagination', paginate: paginate -%}
          </div>
        {%- endif -%}
      {%- else -%}
        {%- comment -%} Nenhum resultado {%- endcomment -%}
        <div class="text-center py-20">
          <svg class="w-16 h-16 mx-auto text-foreground/25 mb-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <h2 class="text-2xl font-light tracking-tight mb-2">{{ 'general.search.no_results_title' | t }}</h2>
          <p class="text-sm text-foreground/55 mb-6">
            {{ 'general.search.no_results_text_html' | t: terms: search.terms }}
          </p>

          {%- if section.settings.show_suggestions -%}
            <div class="max-w-md mx-auto">
              <h3 class="text-xs uppercase tracking-[0.18em] text-foreground/60 mb-4">{{ 'general.search.suggestions_title' | t }}</h3>
              <ul class="text-left text-sm text-foreground/55 space-y-2">
                <li>• {{ 'general.search.suggestion_1' | t }}</li>
                <li>• {{ 'general.search.suggestion_2' | t }}</li>
                <li>• {{ 'general.search.suggestion_3' | t }}</li>
                <li>• {{ 'general.search.suggestion_4' | t }}</li>
              </ul>
            </div>
          {%- endif -%}

          <a href="{{ routes.all_products_collection_url }}" class="inline-flex items-center mt-8 bg-foreground text-background text-xs uppercase tracking-[0.18em] px-6 py-3.5 hover:opacity-90 transition-opacity">
            {{ 'general.search.view_all_products' | t }}
          </a>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  {%- else -%}
    {%- comment -%} Página inicial de busca - mostrar sugestões ou categorias populares {%- endcomment -%}
    {%- if section.settings.show_popular_searches -%}
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-xs uppercase tracking-[0.18em] text-foreground/60 mb-5">{{ 'general.search.popular_searches' | t }}</h2>
        <div class="flex flex-wrap gap-2 justify-center">
          {%- assign popular_terms = section.settings.popular_terms | split: ',' -%}
          {%- for term in popular_terms -%}
            <a
              href="{{ routes.search_url }}?q={{ term | strip | url_encode }}"
              class="px-5 py-2 border border-border hover:border-foreground/30 rounded-full text-xs uppercase tracking-[0.12em] text-foreground/70 transition-colors"
            >
              {{ term | strip }}
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

<script>
  // Filtro por tipo (se habilitado)
  const filterButtons = document.querySelectorAll('.filter-button');
  const searchSections = document.querySelectorAll('.search-section');

  filterButtons.forEach(button => {
    button.addEventListener('click', function() {
      const filter = this.getAttribute('data-filter');

      // Atualizar botões ativos (aparência controlada pela regra CSS .filter-button.active)
      filterButtons.forEach(btn => btn.classList.remove('active'));
      this.classList.add('active');

      // Filtrar seções
      searchSections.forEach(section => {
        if (filter === 'all') {
          section.style.display = 'block';
        } else {
          section.style.display = section.getAttribute('data-section') === filter ? 'block' : 'none';
        }
      });
    });
  });

</script>

<style>
  /* CSS real: o Tailwind não processa @apply em blocos de estilo dentro de .liquid */
  .filter-button.active {
    background-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    border-color: rgb(var(--color-foreground));
  }
</style>

{% schema %}
{
  "name": "t:sections.main_search.name",
  "class": "section-search",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main_search.settings.layout_header.content"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 12,
      "label": "t:sections.main_search.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "t:sections.main_search.settings.products_per_row.label"
    },
    {
      "type": "header",
      "content": "t:sections.main_search.settings.filters_header.content"
    },
    {
      "type": "checkbox",
      "id": "enable_type_filter",
      "label": "t:sections.main_search.settings.enable_type_filter.label",
      "default": true,
      "info": "t:sections.main_search.settings.enable_type_filter.info"
    },
    {
      "type": "header",
      "content": "t:sections.main_search.settings.no_results_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_suggestions",
      "label": "t:sections.main_search.settings.show_suggestions.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main_search.settings.popular_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_popular_searches",
      "label": "t:sections.main_search.settings.show_popular_searches.label",
      "default": true,
      "info": "t:sections.main_search.settings.show_popular_searches.info"
    },
    {
      "type": "text",
      "id": "popular_terms",
      "label": "t:sections.main_search.settings.popular_terms.label",
      "default": "vestidos, blusas, calças, saias, acessórios",
      "info": "t:sections.main_search.settings.popular_terms.info"
    }
  ]
}
{% endschema %}
