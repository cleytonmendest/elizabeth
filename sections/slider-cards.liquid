{% assign loop = section.settings.loop %}
{% assign nav = section.settings.nav %}
{% assign qty_desk = section.settings['qty-desk'] %}
{% assign qty_tab = section.settings['qty-tablet'] %}
{% assign qty_mob = section.settings['qty-mob'] %}
{% assign autoplay = section.settings.autoplay %}
{% assign play_time = section.settings['play-time'] %}
{% assign pause_hover = section.settings['pause-hover'] %}
{% assign dot = section.settings.dot %}

<div
  data-section-id="{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} page-width"
>
  {% if section.settings.title != blank or nav %}
    <div class="flex items-end mt-4 lg:mt-8 {% if section.settings.title == blank and nav %}justify-end{% else %}justify-between{% endif %}">
      {% if section.settings.title != blank %}
        <h2 class="text-2xl md:text-3xl font-light tracking-tight text-foreground">{{ section.settings.title }}</h2>
      {% endif %}
      {% if nav %}
        <div class="flex gap-2 shrink-0">
          <button
            onclick="sliderPrev('{{ section.id }}')"
            aria-label="{{ 'sections.slider.previous' | t }}"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-border text-foreground hover:bg-foreground hover:text-background transition-colors"
          >
            {% render 'icon-angle-left', size: 18 %}
          </button>
          <button
            onclick="sliderNext('{{ section.id }}')"
            aria-label="{{ 'sections.slider.next' | t }}"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-border text-foreground hover:bg-foreground hover:text-background transition-colors"
          >
            {% render 'icon-angle-right', size: 18 %}
          </button>
        </div>
      {% endif %}
    </div>
  {% endif %}
  <my-slider
    class="block w-full overflow-hidden mt-4 lg:mt-8"
    data-section-id="{{ section.id }}"
    data-loop="{{ loop }}"
    data-nav-arrows="{{ nav }}"
    data-qty-desk="{{ qty_desk }}"
    data-qty-tab="{{ qty_tab }}"
    data-qty-mob="{{ qty_mob }}"
    data-autoplay="{{ autoplay }}"
    data-ap-time="{{ play_time }}"
    data-pause-hover="{{ pause_hover }}"
    data-dot="{{ dot }}"
    data-peek="{{ section.settings.peek }}"
    data-items="{{ section.blocks.size }}"
  >
    {% comment %} OBRIGATORIO TER A DIV "my-slider__container" PARA O CORRETO FUNCIONAMENTO {% endcomment %}
    <div class="my-slider__container">
      {%- for block in section.blocks -%}
        <div class="item px-3">
          <a href="{{ block.settings.link }}" class="group block relative overflow-hidden rounded-theme">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag: alt: block.settings.title, class: 'w-full aspect-[3/4] object-cover transition-transform duration-500 ease-out group-hover:scale-105', loading: 'lazy'
              }}
            {%- else -%}
              <div class="w-full aspect-[3/4] bg-foreground/5"></div>
            {%- endif -%}
            <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(0deg, rgba(0,0,0,.5) 0%, transparent 45%)"></div>
            <h3 class="absolute bottom-4 left-0 right-0 text-center text-white text-sm uppercase tracking-[0.16em]">
              {{ block.settings.title }}
            </h3>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </my-slider>
</div>

{% schema %}
{
  "name": "t:sections.slider_cards.name",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.slider_cards.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.slider_cards.settings.title.label",
      "default": "Título da Seção"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "t:sections.slider_cards.settings.loop.label",
      "info": "t:sections.slider_cards.settings.loop.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "nav",
      "label": "t:sections.slider_cards.settings.nav.label",
      "info": "t:sections.slider_cards.settings.nav.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dot",
      "label": "t:sections.slider_cards.settings.dot.label",
      "info": "t:sections.slider_cards.settings.dot.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "peek",
      "label": "t:sections.slider_cards.settings.peek.label",
      "info": "t:sections.slider_cards.settings.peek.info",
      "default": true
    },
    {
      "type": "range",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "t:sections.slider_cards.settings.qty_desk.label",
      "id": "qty-desk",
      "default": 3
    },
    {
      "type": "range",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "t:sections.slider_cards.settings.qty_tablet.label",
      "id": "qty-tablet",
      "default": 2
    },
    {
      "type": "range",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "t:sections.slider_cards.settings.qty_mob.label",
      "id": "qty-mob",
      "default": 1
    },
    {
      "type": "checkbox",
      "label": "t:sections.slider_cards.settings.autoplay.label",
      "id": "autoplay",
      "info": "t:sections.slider_cards.settings.autoplay.info",
      "default": true
    },
    {
      "type": "range",
      "id": "play-time",
      "max": 20,
      "min": 1,
      "step": 1,
      "label": "t:sections.slider_cards.settings.play_time.label",
      "unit": "s",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "pause-hover",
      "label": "t:sections.slider_cards.settings.pause_hover.label",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "t:sections.slider_cards.blocks.card.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.slider_cards.blocks.card.settings.title.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.slider_cards.blocks.card.settings.link.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.slider_cards.blocks.card.settings.image.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.slider_cards.presets.name",
      "blocks": []
    }
  ]
}
{% endschema %}
