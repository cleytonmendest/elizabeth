{%- comment -%}
  Modal de Newsletter com triggers inteligentes
  - Trigger por tempo (delay configurável)
  - Trigger por scroll (% da página)
  - Exit intent detection
  - Cookie para não mostrar novamente
{%- endcomment -%}

{%- if section.settings.enable_modal -%}
{{ 'newsletter-modal.css' | asset_url | stylesheet_tag }}

<newsletter-modal
  class="newsletter-modal fixed inset-0 z-[9999] hidden items-center justify-center color-overlay-dark backdrop-blur-sm"
  data-delay="{{ section.settings.delay_seconds }}"
  data-scroll-trigger="{{ section.settings.scroll_percentage }}"
  data-enable-exit-intent="{{ section.settings.enable_exit_intent }}"
  data-cookie-days="{{ section.settings.cookie_days }}"
>
  <div
    class="newsletter-modal-content color-{{ section.settings.color_scheme }} color-background rounded-theme-lg color-shadow-xl w-full mx-4 relative overflow-hidden transition-all duration-300 opacity-0 scale-95"
    style="max-width: {{ section.settings.modalWidth }}px;"
  >
    {%- comment -%} Botão Fechar {%- endcomment -%}
    <button
      type="button"
      class="close-modal absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full hover:bg-foreground/5 hover:bg-opacity-10 transition-colors z-10"
      aria-label="{{ 'general.accessibility.close_modal' | t }}"
    >
      <svg class="w-5 h-5 color-icon-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div class="p-8 md:p-10">
      {%- comment -%} Imagem/Ícone {%- endcomment -%}
      {%- if section.settings.modal_image != blank -%}
        <div class="mb-6 flex justify-center">
          <img
            src="{{ section.settings.modal_image | image_url: width: 200 }}"
            alt="{{ section.settings.modal_title }}"
            width="{{ section.settings.modal_image.width }}"
            height="{{ section.settings.modal_image.height }}"
            class="w-32 h-32 object-contain"
            loading="lazy"
            decoding="async"
          >
        </div>
      {%- else -%}
        <div class="mb-6 flex justify-center">
          <svg class="w-14 h-14 color-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
        </div>
      {%- endif -%}

      {%- comment -%} Título {%- endcomment -%}
      <h2 class="text-2xl md:text-3xl font-light tracking-tight text-center mb-3 color-text">
        {{ section.settings.modal_title }}
      </h2>

      {%- comment -%} Texto {%- endcomment -%}
      {%- if section.settings.modal_text != blank -%}
        <div class="text-center color-text-muted mb-6">
          {{ section.settings.modal_text }}
        </div>
      {%- endif -%}

      {%- comment -%} Formulário {%- endcomment -%}
      <form
        class="newsletter-form"
        id="newsletter-modal-form"
        data-success-message="{{ section.settings.success_message }}"
        data-error-message="{{ section.settings.error_message }}"
      >
        <div class="mb-4">
          <input
            type="email"
            name="email"
            id="newsletter-email"
            placeholder="{{ 'newsletter.placeholder' | t }}"
            required
            class="color-input w-full px-4 py-3 rounded-theme focus:outline-none focus:ring-2 transition-all"
          >
        </div>

        {%- comment -%} Botão Submit {%- endcomment -%}
        <button
          type="submit"
          class="submit-btn color-button w-full text-xs font-medium uppercase tracking-[0.18em] py-3.5 px-6 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span class="submit-text">{{ section.settings.button_text }}</span>
          <span class="loading-spinner hidden">
            <svg class="animate-spin h-5 w-5 mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </span>
        </button>

        {%- comment -%} Mensagens de Feedback {%- endcomment -%}
        <div class="feedback-message mt-4 hidden">
          <p class="feedback-text text-sm text-center font-medium"></p>
        </div>
      </form>

      {%- comment -%} Checkbox "Não mostrar novamente" {%- endcomment -%}
      {%- if section.settings.show_dont_show_again -%}
        <div class="mt-6 text-center">
          <label class="inline-flex items-center cursor-pointer text-sm color-text-muted hover:opacity-80">
            <input type="checkbox" class="dont-show-again mr-2 rounded-theme-sm color-border">
            {{ 'newsletter.modal.dont_show_again' | t }}
          </label>
        </div>
      {%- endif -%}
    </div>
  </div>
</newsletter-modal>

<script src="{{ 'newsletter-modal.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.newsletter_modal.name",
  "tag": "section",
  "class": "section",
  "limit": 1,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.newsletter_modal.settings.general_header.content"
    },
    {
      "type": "checkbox",
      "id": "enable_modal",
      "label": "t:sections.newsletter_modal.settings.enable_modal.label",
      "default": true,
      "info": "t:sections.newsletter_modal.settings.enable_modal.info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.newsletter_modal.settings.color_scheme.label",
      "default": "scheme-1",
      "info": "t:sections.newsletter_modal.settings.color_scheme.info"
    },
    {
      "type": "number",
      "id": "modalWidth",
      "label": "t:sections.newsletter_modal.settings.modalWidth.label",
      "default": 500
    },
    {
      "type": "header",
      "content": "t:sections.newsletter_modal.settings.content_header.content"
    },
    {
      "type": "image_picker",
      "id": "modal_image",
      "label": "t:sections.newsletter_modal.settings.modal_image.label",
      "info": "t:sections.newsletter_modal.settings.modal_image.info"
    },
    {
      "type": "inline_richtext",
      "label": "t:sections.newsletter_modal.settings.modal_title.label",
      "id": "modal_title",
      "default": "Receba ofertas exclusivas!"
    },
    {
      "type": "richtext",
      "id": "modal_text",
      "label": "t:sections.newsletter_modal.settings.modal_text.label",
      "default": "<p>Cadastre-se e receba em primeira mão nossas promoções e lançamentos.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.newsletter_modal.settings.button_text.label",
      "default": "Quero receber ofertas"
    },
    {
      "type": "header",
      "content": "t:sections.newsletter_modal.settings.triggers_header.content"
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "t:sections.newsletter_modal.settings.delay_seconds.label",
      "default": 5,
      "info": "t:sections.newsletter_modal.settings.delay_seconds.info"
    },
    {
      "type": "range",
      "id": "scroll_percentage",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:sections.newsletter_modal.settings.scroll_percentage.label",
      "default": 0,
      "info": "t:sections.newsletter_modal.settings.scroll_percentage.info"
    },
    {
      "type": "checkbox",
      "id": "enable_exit_intent",
      "label": "t:sections.newsletter_modal.settings.enable_exit_intent.label",
      "default": true,
      "info": "t:sections.newsletter_modal.settings.enable_exit_intent.info"
    },
    {
      "type": "header",
      "content": "t:sections.newsletter_modal.settings.cookies_header.content"
    },
    {
      "type": "range",
      "id": "cookie_days",
      "min": 10,
      "max": 370,
      "step": 10,
      "unit": "dia",
      "label": "t:sections.newsletter_modal.settings.cookie_days.label",
      "default": 30,
      "info": "t:sections.newsletter_modal.settings.cookie_days.info"
    },
    {
      "type": "checkbox",
      "id": "show_dont_show_again",
      "label": "t:sections.newsletter_modal.settings.show_dont_show_again.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.newsletter_modal.settings.feedback_header.content"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "t:sections.newsletter_modal.settings.success_message.label",
      "default": "Obrigado! Você receberá nossas novidades em breve."
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "t:sections.newsletter_modal.settings.error_message.label",
      "default": "Ops! Algo deu errado. Tente novamente."
    }
  ],
  "presets": [
    {
      "name": "t:sections.newsletter_modal.presets.name"
    }
  ]
}
{% endschema %}
