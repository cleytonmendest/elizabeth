{%- comment -%}
  Produtos vistos recentemente — via localStorage (sem setup do lojista).
  Na PDP registra o produto atual; para exibir, o <recently-viewed> busca os cards
  pela Section Rendering API (busca nativa q=id:…), reutilizando o card Liquid.
  Exibição adaptável (grid ou slider) via snippet product-showcase.
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'product.recently_viewed.title' | t
  endif
  assign limit = section.settings.products_to_show | default: 8
  assign show_nav = false
  if section.settings.desktop_layout == 'slider'
    assign show_nav = true
  endif

  assign rv_count = 0
  if search.performed
    for item in search.results
      if item.object_type == 'product'
        assign rv_count = rv_count | plus: 1
      endif
    endfor
  endif
-%}

<recently-viewed
  class="block"
  data-section-id="{{ section.id }}"
  data-search-url="{{ routes.search_url }}"
  data-limit="{{ limit }}"
  {% if product %}data-product-id="{{ product.id }}"{% endif %}
>
  {%- if search.performed and rv_count > 0 -%}
    <div class="color-{{ section.settings.color_scheme }} color-background color-text">
      <div class="page-width !py-12 lg:!py-16">
        {% render 'product-showcase-header',
          heading: heading,
          subtitle: section.settings.subtitle,
          alignment: section.settings.text_alignment,
          show_nav: show_nav,
          section_id: section.id
        %}
        {%- assign rv_products = search.results | where: 'object_type', 'product' -%}
        {% render 'product-showcase',
          products: rv_products,
          products_count: rv_count,
          layout: section.settings.desktop_layout,
          columns: section.settings.columns,
          section_id: section.id,
          limit: limit,
          show_second_image: section.settings.show_second_image,
          show_installments: section.settings.show_installments,
          show_quick_add: section.settings.show_quick_add
        %}
      </div>
    </div>
  {%- endif -%}
</recently-viewed>

<script src="{{ 'recently-viewed.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.recently_viewed.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.recently_viewed.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.recently_viewed.settings.heading.label",
      "info": "t:sections.recently_viewed.settings.heading.info"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.recently_viewed.settings.subtitle.label"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:sections.recently_viewed.settings.text_alignment.label",
      "default": "center",
      "options": [
        { "value": "left", "label": "t:sections.recently_viewed.settings.text_alignment.options.left" },
        { "value": "center", "label": "t:sections.recently_viewed.settings.text_alignment.options.center" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.recently_viewed.settings.layout_header.content"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "t:sections.recently_viewed.settings.desktop_layout.label",
      "info": "t:sections.recently_viewed.settings.desktop_layout.info",
      "default": "slider",
      "options": [
        { "value": "slider", "label": "t:sections.recently_viewed.settings.desktop_layout.options.slider" },
        { "value": "grid", "label": "t:sections.recently_viewed.settings.desktop_layout.options.grid" }
      ]
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "t:sections.recently_viewed.settings.columns.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8,
      "label": "t:sections.recently_viewed.settings.products_to_show.label",
      "info": "t:sections.recently_viewed.settings.products_to_show.info"
    },
    {
      "type": "header",
      "content": "t:sections.recently_viewed.settings.card_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_second_image",
      "label": "t:sections.recently_viewed.settings.show_second_image.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "t:sections.recently_viewed.settings.show_quick_add.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_installments",
      "label": "t:sections.recently_viewed.settings.show_installments.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.recently_viewed.presets.name"
    }
  ]
}
{% endschema %}
