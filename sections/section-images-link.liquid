<section class="color-{{ section.settings.color_scheme }} page-width !py-4 !lg:py-6">
  <div class="flex flex-col lg:flex-row">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="group relative flex-1 block overflow-hidden">
        {%- if block.settings.image != blank -%}
          {{
            block.settings.image
            | image_url: width: 1500
            | image_tag: alt: block.settings.label, class: 'w-full aspect-[4/3] object-cover transition-transform duration-500 ease-out group-hover:scale-105', loading: 'lazy'
          }}
        {%- else -%}
          <div class="w-full aspect-[4/3] bg-foreground/5"></div>
        {%- endif -%}
        <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(0deg, rgba(0,0,0,.45) 0%, transparent 55%)"></div>
        <span class="absolute bottom-6 left-0 right-0 text-center text-white text-base lg:text-xl font-light uppercase tracking-[0.2em]">
          {{ block.settings.label }}
        </span>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.section_images_link.name",
  "tag": "section",
  "max_blocks": 2,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.section_images_link.settings.color_scheme.label",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "name": "t:sections.section_images_link.blocks.image.name",
      "type": "image",
      "settings": [
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.section_images_link.blocks.image.settings.link.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.section_images_link.blocks.image.settings.image.label"
        },
        {
            "type": "text",
            "id": "label",
            "label": "t:sections.section_images_link.blocks.image.settings.label.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.section_images_link.presets.name",
      "blocks": [
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
