{% assign loop = section.settings.loop %}
{% assign nav = section.settings.nav %}
{% assign qty_desk = section.settings['qty-desk'] %}
{% assign qty_tab = section.settings['qty-tablet'] %}
{% assign qty_mob = section.settings['qty-mob'] %}
{% assign autoplay = section.settings.autoplay %}
{% assign play_time = section.settings['play-time'] %}
{% assign pause_hover = section.settings['pause-hover'] %}
{% assign dot = section.settings.dot %}

<div class="color-{{ section.settings.color_scheme }} page-width">
  <div class="flex items-end mb-6
    {% if section.settings.title == blank and nav %} justify-end
    {% elsif section.settings.title != blank and nav == false %} justify-start
    {% else %} justify-between
     {% endif %}">
    <div>
      <h2 class="text-2xl md:text-3xl font-light tracking-tight text-foreground">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle != blank %}
        <div class="text-sm text-foreground/70 mt-1">
          {{ section.settings.subtitle }}
        </div>
      {% endif %}
    </div>
    {% if nav %}
      <div class="flex gap-2 shrink-0">
        <button
          onclick="sliderPrev('{{ section.id }}')"
          aria-label="{{ 'sections.slider.previous' | t }}"
          class="w-9 h-9 flex items-center justify-center rounded-full border border-border text-foreground hover:bg-foreground hover:text-background transition-colors"
        >
          {% render 'icon-angle-left', size: 18 %}
        </button>
        <button
          onclick="sliderNext('{{ section.id }}')"
          aria-label="{{ 'sections.slider.next' | t }}"
          class="w-9 h-9 flex items-center justify-center rounded-full border border-border text-foreground hover:bg-foreground hover:text-background transition-colors"
        >
          {% render 'icon-angle-right', size: 18 %}
        </button>
      </div>
    {% endif %}
  </div>
  <div class="product-slider-container slider-container">
    <my-slider
      class="w-full relative"
      data-section-id="{{ section.id }}"
      data-loop="{{ loop }}"
      data-items="{{ section.settings.collection.products_count }}"
      data-qty-desk="{{ qty_desk }}"
      data-qty-tab="{{ qty_tab }}"
      data-qty-mob="{{ qty_mob }}"
      data-autoplay="{{ autoplay }}"
      data-ap-time="{{ play_time }}"
      data-pause-hover="{{ pause_hover }}"
      data-dot="{{ dot }}"
    >
      {% comment %} OBRIGATORIO TER A DIV "my-slider__container" PARA O CORRETO FUNCIONAMENTO {% endcomment %}
      <div class="my-slider__container overflow-hidden">
        {%- for product in section.settings.collection.products -%}
          <div class="carousel-item">
            {% render 'card-product-slider', card_product: product, show_quick_add: section.settings.show_quick_add %}
          </div>
        {% endfor %}
      </div>
    </my-slider>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.slider_product.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.slider_product.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.slider_product.settings.collection.label"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "t:sections.slider_product.settings.show_quick_add.label",
      "info": "t:sections.slider_product.settings.show_quick_add.info",
      "default": true
    },
    {
      "type": "inline_richtext",
      "label": "t:sections.slider_product.settings.title.label",
      "id": "title"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "t:sections.slider_product.settings.subtitle.label"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "t:sections.slider_product.settings.loop.label",
      "info": "t:sections.slider_product.settings.loop.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "nav",
      "label": "t:sections.slider_product.settings.nav.label",
      "info": "t:sections.slider_product.settings.nav.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dot",
      "label": "t:sections.slider_product.settings.dot.label",
      "info": "t:sections.slider_product.settings.dot.info",
      "default": true
    },
    {
      "type": "range",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "t:sections.slider_product.settings.qty_desk.label",
      "id": "qty-desk",
      "default": 5
    },
    {
      "type": "range",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "t:sections.slider_product.settings.qty_tablet.label",
      "id": "qty-tablet",
      "default": 3
    },
    {
      "type": "range",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "t:sections.slider_product.settings.qty_mob.label",
      "id": "qty-mob",
      "default": 1
    },
    {
      "type": "checkbox",
      "label": "t:sections.slider_product.settings.autoplay.label",
      "id": "autoplay",
      "info": "t:sections.slider_product.settings.autoplay.info",
      "default": true
    },
    {
      "type": "range",
      "id": "play-time",
      "max": 20,
      "min": 1,
      "step": 1,
      "label": "t:sections.slider_product.settings.play_time.label",
      "unit": "s",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "pause-hover",
      "label": "t:sections.slider_product.settings.pause_hover.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.slider_product.presets.name",
      "blocks": []
    }
  ]
}
{% endschema %}
