<script src="{{ 'header.js' | asset_url }}" async></script>

{%- liquid
  assign fixed = section.settings.fixed_header

  if fixed
    assign header_type = 'fixed'
  else
    assign header_type = 'basic'
  endif

  case section.settings['menu-type']
    when 'centered-logo-menu-under'
      assign logo_center = true
      assign menu_under = true
      assign search_position = 'left'
      assign search_hidden = false
    when 'logo-left-centered-menu'
      assign logo_center = false
      assign menu_under = false
      assign search_position = 'right'
      assign search_hidden = false
    when 'logo-left-centered-menu-search-hidden'
      assign logo_center = false
      assign menu_under = false
      assign search_position = 'right'
      assign search_hidden = true
    when 'logo-left-menu-under-centered-search'
      assign logo_center = false
      assign menu_under = true
      assign search_position = 'center'
      assign search_hidden = false
    else
      assign logo_center = false
      assign menu_under = true
      assign search_position = 'center'
      assign search_hidden = false
  endcase
-%}

<style>
  {%- if fixed -%}
    #shopify-section-{{ section.id }} {
      position: sticky;
      top: 0;
      z-index: 50;
    }
  {%- endif -%}

  #main-header-container.is-scrolling {
    box-shadow: 0 2px 8px rgb(var(--color-shadow) / 0.1);
  }
</style>

<div class="w-full color-{{ section.settings.color_scheme }}">
  <main-header class="w-full block relative z-10" data-type="{{ header_type }}">
    <div
      id="main-header-container"
      class="color-background w-full transition-shadow duration-300 group relative z-[1]"
    >
      <div class="!py-3 page-width w-full">
        <div class="flex justify-between">
          {% if logo_center == false %}
            {% render 'logo' %}
          {% endif %}
          {% if search_position == 'left' and search_hidden == false %}
            {% render 'search-component', flex: 1, large:false %}
          {% endif %}
          {% if logo_center %}
            {% render 'logo' %}
          {% endif %}
          {% if search_position == 'center' and search_hidden == false %}
            {% render 'search-component', flex: 3, large:true %}
          {% endif %}
          {% if menu_under == false %}
            {% render 'main-menu', linklist: section.settings.menu, flex: 5 %}
          {% endif %}
          {% if search_position == 'right' and search_hidden == false %}
            {% render 'search-component', flex: 1.5, showMobile: false, large:false %}
          {% endif %}

          {% render 'header-icons', flex: 1 %}
        </div>
        {% if menu_under %}
          {% render 'main-menu', linklist: section.settings.menu, flex: 1 %}
        {% endif %}
      </div>
    </div>
    {%- comment -%} Overlay da busca preditiva: cobre a página, mas fica atrás do header (z menor que o container) {%- endcomment -%}
    <div class="search-overlay fixed inset-0 bg-foreground/40 z-0 hidden"></div>
  </main-header>
</div>

{% schema %}
{
  "name": "t:sections.header.name",
  "tag": "header",
  "class": "header",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.header.settings.color_scheme.label",
      "default": "scheme-1",
      "info": "t:sections.header.settings.color_scheme.info"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "select",
      "id": "menu-type",
      "label": "t:sections.header.settings.menu_type.label",
      "options": [
        {
          "value": "centered-logo-menu-under",
          "label": "t:sections.header.settings.menu_type.options.centered_logo_menu_under"
        },
        {
          "value": "logo-left-centered-menu",
          "label": "t:sections.header.settings.menu_type.options.logo_left_centered_menu"
        },
        {
          "value": "logo-left-centered-menu-search-hidden",
          "label": "t:sections.header.settings.menu_type.options.logo_left_centered_menu_search_hidden"
        },
        {
          "value": "logo-left-menu-under-centered-search",
          "label": "t:sections.header.settings.menu_type.options.logo_left_menu_under_centered_search"
        }
      ],
      "default": "logo-left-menu-under-centered-search"
    },
    {
      "type": "checkbox",
      "default": true,
      "id": "fixed_header",
      "label": "t:sections.header.settings.fixed_header.label",
      "info": "t:sections.header.settings.fixed_header.info"
    }
  ]
}
{% endschema %}
