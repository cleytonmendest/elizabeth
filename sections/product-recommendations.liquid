{%- comment -%}
  Recomendações de produto — "Você também pode gostar".
  Usa a API nativa de recommendations do Shopify (sem setup do lojista). O conteúdo
  é carregado sob demanda via <product-recommendations> (fetch quando entra na tela).
  Exibição adaptável (grid ou slider) via snippet product-showcase.
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'product.recommendations.title' | t
  endif
  assign limit = section.settings.products_to_show | default: 8
  assign show_nav = false
  if section.settings.desktop_layout == 'slider'
    assign show_nav = true
  endif
-%}

<product-recommendations
  class="block"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ limit }}&intent=related"
>
  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <div class="color-{{ section.settings.color_scheme }} color-background color-text">
      <div class="page-width !py-12 lg:!py-16">
        {% render 'product-showcase-header',
          heading: heading,
          subtitle: section.settings.subtitle,
          alignment: section.settings.text_alignment,
          show_nav: show_nav,
          section_id: section.id
        %}
        {% render 'product-showcase',
          products: recommendations.products,
          products_count: recommendations.products_count,
          layout: section.settings.desktop_layout,
          columns: section.settings.columns,
          section_id: section.id,
          limit: limit,
          show_second_image: section.settings.show_second_image,
          show_installments: section.settings.show_installments,
          show_quick_add: section.settings.show_quick_add
        %}
      </div>
    </div>
  {%- endif -%}
</product-recommendations>

<script src="{{ 'product-recommendations.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.product_recommendations.name",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.product_recommendations.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.product_recommendations.settings.heading.label",
      "info": "t:sections.product_recommendations.settings.heading.info"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.product_recommendations.settings.subtitle.label"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:sections.product_recommendations.settings.text_alignment.label",
      "default": "center",
      "options": [
        { "value": "left", "label": "t:sections.product_recommendations.settings.text_alignment.options.left" },
        { "value": "center", "label": "t:sections.product_recommendations.settings.text_alignment.options.center" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.product_recommendations.settings.layout_header.content"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "t:sections.product_recommendations.settings.desktop_layout.label",
      "info": "t:sections.product_recommendations.settings.desktop_layout.info",
      "default": "slider",
      "options": [
        { "value": "slider", "label": "t:sections.product_recommendations.settings.desktop_layout.options.slider" },
        { "value": "grid", "label": "t:sections.product_recommendations.settings.desktop_layout.options.grid" }
      ]
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "t:sections.product_recommendations.settings.columns.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8,
      "label": "t:sections.product_recommendations.settings.products_to_show.label",
      "info": "t:sections.product_recommendations.settings.products_to_show.info"
    },
    {
      "type": "header",
      "content": "t:sections.product_recommendations.settings.card_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_second_image",
      "label": "t:sections.product_recommendations.settings.show_second_image.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "t:sections.product_recommendations.settings.show_quick_add.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_installments",
      "label": "t:sections.product_recommendations.settings.show_installments.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_recommendations.presets.name"
    }
  ]
}
{% endschema %}
