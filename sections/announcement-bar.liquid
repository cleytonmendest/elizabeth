<announcement-bar
  data-section-id="{{ section.id }}"
  data-direction="{{ section.settings.direction }}"
  data-duration="{{ section.settings.duration }}"
  data-pauseHover="{{ section.settings.pause_hover }}"
  style="--marquee-duration: {{ section.settings.duration }}s; --marquee-gap: {{ section.settings.gap }}px;"
  class="color-{{ section.settings.color_scheme }} color-background color-text w-full overflow-hidden py-1 lg:py-2 flex"
>
  {%- comment -%}
    O conteúdo é renderizado uma vez; o JS (announcement-bar) clona até preencher
    a viewport e duplica a trilha para o loop contínuo (translateX 0 -> -50%).
    Sem JS, fica estático (degradação graciosa).
  {%- endcomment -%}
  <div class="announcement-marquee">
    <div class="announcement-track">
      {%- for block in section.blocks -%}
        <div class="inline-block px-2 text-xs lg:text-base">
          {{ block.settings.text_item }}
        </div>
        <span class="inline-block px-2">•</span>
      {%- endfor -%}
    </div>
  </div>
</announcement-bar>

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "max_blocks": 15,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.announcement_bar.settings.color_scheme.label",
      "default": "scheme-1",
      "info": "t:sections.announcement_bar.settings.color_scheme.info"
    },
    {
      "type": "range",
      "id": "duration",
      "label": "t:sections.announcement_bar.settings.duration.label",
      "unit": "s",
      "default": 40,
      "min": 10,
      "max": 60,
      "step": 1
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:sections.announcement_bar.settings.gap.label",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:sections.announcement_bar.settings.direction.label",
      "default": "left",
      "options": [
        { "value": "left", "label": "t:sections.announcement_bar.settings.direction.options.left" },
        { "value": "right", "label": "t:sections.announcement_bar.settings.direction.options.right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "pause_hover",
      "label": "t:sections.announcement_bar.settings.pause_hover.label",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "t:sections.announcement_bar.blocks.text.name",
      "settings": [
        {
          "type": "richtext",
          "id": "text_item",
          "label": "t:sections.announcement_bar.blocks.text.settings.text_item.label",
          "default": "<p>Up to <strong>12x interest-free!</strong></p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement_bar.presets.name",
      "blocks": []
    }
  ]
}
{% endschema %}
