{% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
{%- assign products_per_page = section.settings.products_per_page | default: 12 -%}

{%- comment -%}
  Detecção de moeda com vírgula decimal (ex: BRL, EUR) para os inputs do filtro de
  preço — o param do Shopify espera ponto decimal e sem separador de milhar.
{%- endcomment -%}
{%- assign comma_currencies = 'ANG,ARS,BRL,BYN,CLF,CLP,COP,CRC,CZK,DKK,EUR,HRK,HUF,IDR,ISK,MZN,NOK,PLN,RON,RUB,SEK,TRY,UYU,VND' | split: ',' -%}
{%- assign uses_comma_decimals = false -%}
{%- if comma_currencies contains cart.currency.iso_code -%}
  {%- assign uses_comma_decimals = true -%}
{%- endif -%}

{%- comment -%} Conta filtros ativos (para "limpar" e estados) {%- endcomment -%}
{%- assign active_filter_count = 0 -%}
{%- for filter in collection.filters -%}
  {%- if filter.type == 'price_range' -%}
    {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
      {%- assign active_filter_count = active_filter_count | plus: 1 -%}
    {%- endif -%}
  {%- else -%}
    {%- assign active_filter_count = active_filter_count | plus: filter.active_values.size -%}
  {%- endif -%}
{%- endfor -%}

<div class="page-width !py-8 color-{{ section.settings.color_scheme }}">
  {%- if collection.image and section.settings.show_collection_image -%}
    <div class="collection-hero mb-10 md:mb-12 relative h-64 md:h-[26rem] rounded-theme overflow-hidden">
      <img
        src="{{ collection.image | image_url: width: 1600 }}"
        srcset="{{ collection.image | image_url: width: 600 }} 600w,
                {{ collection.image | image_url: width: 1200 }} 1200w,
                {{ collection.image | image_url: width: 1600 }} 1600w"
        sizes="100vw"
        alt="{{ collection.image.alt | escape }}"
        class="w-full h-full object-cover"
        width="{{ collection.image.width }}"
        height="{{ collection.image.height }}"
        loading="eager"
      >
      <div class="absolute inset-0 bg-black/30 flex flex-col items-center justify-center text-center px-4">
        <h1 class="text-white text-3xl md:text-5xl font-light tracking-tight">
          {{ collection.title }}
        </h1>
        {%- if collection.description != blank and section.settings.show_collection_description -%}
          <div class="text-white/80 text-sm md:text-base max-w-2xl mx-auto mt-4">
            {{ collection.description }}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- else -%}
    <div class="text-center mb-10 md:mb-12">
      <h1 class="text-3xl md:text-4xl font-light tracking-tight mb-3">{{ collection.title }}</h1>
      {%- if collection.description != blank and section.settings.show_collection_description -%}
        <div class="text-sm text-foreground/55 max-w-2xl mx-auto">
          {{ collection.description }}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- assign show_filters = false -%}
  {%- if section.settings.enable_filtering and collection.filters.size > 0 -%}
    {%- assign show_filters = true -%}
  {%- endif -%}

  {%- paginate collection.products by products_per_page -%}
    <form data-filter-form method="get" class="flex flex-col lg:flex-row gap-8">
      {%- if show_filters -%}
        {%- comment -%} Filtros nativos: sidebar inline no desktop, drawer off-canvas no mobile {%- endcomment -%}
        <div
          class="fixed inset-0 z-40 bg-black/40 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
          data-filters-overlay
        ></div>
        <aside
          class="filters-panel fixed inset-y-0 left-0 z-50 w-80 max-w-[85vw] -translate-x-full overflow-y-auto bg-background p-6 transition-transform duration-300 lg:static lg:z-auto lg:w-64 lg:max-w-none lg:translate-x-0 lg:overflow-visible lg:bg-transparent lg:p-0 lg:transition-none flex-shrink-0"
          data-filters-panel
          aria-label="{{ 'collection.filters.title' | t }}"
        >
          <div class="lg:sticky lg:top-20">
            {%- comment -%} Cabeçalho do drawer (somente mobile) {%- endcomment -%}
            <div class="flex items-center justify-between mb-6 lg:hidden">
              <h2 class="text-xs uppercase tracking-[0.18em] text-foreground/60">{{ 'collection.filters.title' | t }}</h2>
              <button
                type="button"
                data-filters-close
                aria-label="{{ 'collection.filters.close' | t }}"
                class="text-foreground/60 hover:text-foreground transition-colors"
              >
                {% render 'icon-close', size: 20 %}
              </button>
            </div>

            <div class="flex items-center justify-between mb-5">
              <h2 class="hidden lg:block text-xs uppercase tracking-[0.18em] text-foreground/60">{{ 'collection.filters.title' | t }}</h2>
              {%- if active_filter_count > 0 -%}
                <a
                  href="{{ collection.url }}{% if sort_by != blank %}?sort_by={{ sort_by }}{% endif %}"
                  class="text-xs uppercase tracking-[0.12em] text-foreground/55 hover:text-foreground underline underline-offset-4 transition-colors"
                >
                  {{ 'collection.filters.clear_all' | t }}
                </a>
              {%- endif -%}
            </div>

            {%- comment -%} Preserva a ordenação ao aplicar filtros {%- endcomment -%}
            <input type="hidden" name="sort_by" value="{{ sort_by }}">

            {%- for filter in collection.filters -%}
              <details class="mb-4 border-b border-border pb-4" open>
                <summary class="cursor-pointer list-none text-sm font-medium flex justify-between items-center gap-2">
                  <span>{{ filter.label | escape }}</span>
                  <span class="filter-chevron shrink-0 transition-transform opacity-60">
                    {% render 'icon-angle-down', size: 16 %}
                  </span>
                </summary>

                {%- case filter.type -%}
                  {%- when 'price_range' -%}
                    {%- liquid
                      assign min_input = ''
                      assign max_input = ''
                      if filter.min_value.value != blank
                        if uses_comma_decimals
                          assign min_input = filter.min_value.value | money_without_currency | replace: '.', '' | replace: ',', '.'
                        else
                          assign min_input = filter.min_value.value | money_without_currency | replace: ',', ''
                        endif
                      endif
                      if filter.max_value.value != blank
                        if uses_comma_decimals
                          assign max_input = filter.max_value.value | money_without_currency | replace: '.', '' | replace: ',', '.'
                        else
                          assign max_input = filter.max_value.value | money_without_currency | replace: ',', ''
                        endif
                      endif
                      if uses_comma_decimals
                        assign range_max = filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.'
                      else
                        assign range_max = filter.range_max | money_without_currency | replace: ',', ''
                      endif
                    -%}
                    <div class="mt-3 flex items-center gap-2">
                      <div class="flex items-center gap-1 flex-1">
                        <span class="text-xs text-foreground/55">{{ cart.currency.symbol }}</span>
                        <input
                          type="number"
                          inputmode="decimal"
                          name="{{ filter.min_value.param_name }}"
                          value="{{ min_input }}"
                          placeholder="0"
                          min="0"
                          max="{{ range_max }}"
                          aria-label="{{ 'collection.filters.from' | t }}"
                          class="w-full border border-border rounded-theme-sm px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-foreground/40"
                        >
                      </div>
                      <span class="text-foreground/40">—</span>
                      <div class="flex items-center gap-1 flex-1">
                        <span class="text-xs text-foreground/55">{{ cart.currency.symbol }}</span>
                        <input
                          type="number"
                          inputmode="decimal"
                          name="{{ filter.max_value.param_name }}"
                          value="{{ max_input }}"
                          placeholder="{{ range_max }}"
                          min="0"
                          max="{{ range_max }}"
                          aria-label="{{ 'collection.filters.to' | t }}"
                          class="w-full border border-border rounded-theme-sm px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-foreground/40"
                        >
                      </div>
                    </div>

                  {%- else -%}
                    <div class="mt-3 space-y-2 max-h-64 overflow-y-auto">
                      {%- for value in filter.values -%}
                        {%- liquid
                          assign disabled = false
                          if value.count == 0 and value.active == false
                            assign disabled = true
                          endif
                        -%}
                        <label class="flex items-center gap-2 text-sm cursor-pointer {% if disabled %}opacity-40 cursor-not-allowed{% endif %}">
                          <input
                            type="checkbox"
                            class="filter-checkbox rounded-theme-sm border-border text-foreground focus:ring-foreground/40"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            {% if value.active %}checked{% endif %}
                            {% if disabled %}disabled{% endif %}
                          >
                          <span>{{ value.label | escape }}</span>
                          <span class="text-foreground/40 text-xs">({{ value.count }})</span>
                        </label>
                      {%- endfor -%}
                    </div>
                {%- endcase -%}
              </details>
            {%- endfor -%}

            {%- comment -%} Botão de aplicar (mobile / fallback sem JS) {%- endcomment -%}
            <div class="mt-6 lg:hidden">
              <button
                type="submit"
                class="w-full color-button text-xs uppercase tracking-[0.18em] py-3 hover:opacity-90 transition-opacity"
              >
                {{ 'collection.filters.apply' | t }}
              </button>
            </div>
          </div>
        </aside>
      {%- endif -%}
      {%- comment -%} fim filtros {%- endcomment -%}

      {%- comment -%} Produtos {%- endcomment -%}
      <div class="flex-1">
        {%- comment -%} Barra de ferramentas {%- endcomment -%}
        <div class="grid grid-cols-[1fr_auto_1fr] items-center mb-6 gap-3">
          {%- comment -%} Esquerda: gatilho de filtros (mobile) {%- endcomment -%}
          <div class="justify-self-start">
            {%- if show_filters -%}
              <button
                type="button"
                data-filters-open
                class="lg:hidden inline-flex items-center gap-2 border border-border rounded-theme px-4 py-2 text-sm text-foreground/80 hover:border-foreground/30 transition-colors"
              >
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h18M6 12h12M10 20h4" />
                </svg>
                {{ 'collection.filters.title' | t }}
                {%- if active_filter_count > 0 -%}
                  <span class="color-badge inline-flex items-center justify-center min-w-[18px] h-[18px] rounded-full text-xs px-1">{{ active_filter_count }}</span>
                {%- endif -%}
              </button>
            {%- endif -%}
          </div>

          {%- comment -%} Centro: contagem de produtos {%- endcomment -%}
          <p class="justify-self-center text-center text-sm text-foreground/55">
            {%- assign showing_first = paginate.current_offset | plus: 1 -%}
            {%- assign showing_last = paginate.current_offset | plus: paginate.page_size | at_most: paginate.items -%}
            {{ 'collection.general.results_showing' | t: count: paginate.items, first: showing_first, last: showing_last }}
          </p>

          {%- comment -%} Direita: ordenação {%- endcomment -%}
          <div class="justify-self-end flex items-center gap-2">
            {%- if section.settings.enable_sorting -%}
              <label for="SortBy" class="text-sm font-medium hidden sm:inline">{{ 'collection.sorting.title' | t }}</label>
              <select
                id="SortBy"
                name="sort_by"
                class="border border-border rounded-theme px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-foreground/40"
                aria-describedby="a11y-refresh-page-message"
              >
                <option value="manual" {% if sort_by == 'manual' %}selected{% endif %}>{{ 'collection.sorting.featured' | t }}</option>
                <option value="best-selling" {% if sort_by == 'best-selling' %}selected{% endif %}>{{ 'collection.sorting.best_selling' | t }}</option>
                <option value="title-ascending" {% if sort_by == 'title-ascending' %}selected{% endif %}>{{ 'collection.sorting.az' | t }}</option>
                <option value="title-descending" {% if sort_by == 'title-descending' %}selected{% endif %}>{{ 'collection.sorting.za' | t }}</option>
                <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>{{ 'collection.sorting.price_ascending' | t }}</option>
                <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>{{ 'collection.sorting.price_descending' | t }}</option>
                <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>{{ 'collection.sorting.date_descending' | t }}</option>
                <option value="created-ascending" {% if sort_by == 'created-ascending' %}selected{% endif %}>{{ 'collection.sorting.date_ascending' | t }}</option>
              </select>
            {%- endif -%}
          </div>
        </div>

        {%- if collection.products.size > 0 -%}
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-{{ section.settings.products_per_row }} gap-4 md:gap-6">
            {%- for product in collection.products -%}
              {%- render 'card-product-slider',
                card_product: product,
                show_second_image: section.settings.show_second_image,
                show_badges: true,
                show_installments: section.settings.show_installments,
                lazy_load: true,
                remove_padding: true
              -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <div class="mt-12">
              {%- render 'pagination', paginate: paginate -%}
            </div>
          {%- endif -%}
        {%- else -%}
          <div class="text-center py-20">
            <svg class="w-16 h-16 mx-auto text-foreground/25 mb-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
            </svg>
            {%- if active_filter_count > 0 -%}
              <h2 class="text-2xl font-light tracking-tight mb-2">{{ 'collection.general.no_results' | t }}</h2>
              <p class="text-sm text-foreground/55 mb-8">{{ 'collection.general.no_results_text' | t }}</p>
              <a href="{{ collection.url }}" class="inline-flex items-center color-button text-xs uppercase tracking-[0.18em] px-6 py-3.5 hover:opacity-90 transition-opacity">
                {{ 'collection.filters.clear_all' | t }}
              </a>
            {%- else -%}
              <h2 class="text-2xl font-light tracking-tight mb-2">{{ 'collection.general.no_products' | t }}</h2>
              <p class="text-sm text-foreground/55 mb-8">{{ 'collection.general.empty_text' | t }}</p>
              <a href="{{ routes.collections_url }}" class="inline-flex items-center color-button text-xs uppercase tracking-[0.18em] px-6 py-3.5 hover:opacity-90 transition-opacity">
                {{ 'collection.general.view_all_collections' | t }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </form>
  {%- endpaginate -%}
</div>

<style>
  #shopify-section-{{ section.id }} .filters-panel.is-open { transform: translateX(0); }
  #shopify-section-{{ section.id }} [data-filters-overlay].is-open { opacity: 1; pointer-events: auto; }
  #shopify-section-{{ section.id }} details > summary::-webkit-details-marker { display: none; }
  #shopify-section-{{ section.id }} details[open] .filter-chevron { transform: rotate(180deg); }
</style>

<script>
  (function () {
    const root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;

    // Drawer de filtros (mobile)
    const panel = root.querySelector('[data-filters-panel]');
    const overlay = root.querySelector('[data-filters-overlay]');
    if (panel && overlay) {
      const open = () => {
        panel.classList.add('is-open');
        overlay.classList.add('is-open');
        document.body.classList.add('overflow-hidden');
      };
      const close = () => {
        panel.classList.remove('is-open');
        overlay.classList.remove('is-open');
        document.body.classList.remove('overflow-hidden');
      };
      root.querySelectorAll('[data-filters-open]').forEach((b) => b.addEventListener('click', open));
      root.querySelectorAll('[data-filters-close]').forEach((b) => b.addEventListener('click', close));
      overlay.addEventListener('click', close);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
      window.matchMedia('(min-width: 1024px)').addEventListener('change', (e) => { if (e.matches) close(); });
    }

    // Aplica filtros/ordenação. No desktop, auto-submete ao mudar; no mobile,
    // o usuário usa o botão "Aplicar" (submit nativo). Ordenação sempre submete.
    const form = root.querySelector('[data-filter-form]');
    if (form) {
      const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;
      form.addEventListener('change', (e) => {
        if (e.target.name === 'sort_by') { form.submit(); return; }
        if (isDesktop()) form.submit();
      });
    }

    // Nota de acessibilidade para leitores de tela
    if (!document.getElementById('a11y-refresh-page-message')) {
      const a11yRefreshMessage = document.createElement('span');
      a11yRefreshMessage.id = 'a11y-refresh-page-message';
      a11yRefreshMessage.className = 'sr-only';
      a11yRefreshMessage.setAttribute('role', 'status');
      a11yRefreshMessage.setAttribute('aria-live', 'polite');
      a11yRefreshMessage.textContent = {{ 'collection.general.sort_reloaded' | t | json }};
      document.body.appendChild(a11yRefreshMessage);
    }
  })();
</script>

{%- comment -%} SEO: Breadcrumb Schema {%- endcomment -%}
{% render 'schema-breadcrumb', collection: collection %}

{% schema %}
{
  "name": "t:sections.main_collection.name",
  "class": "section-collection",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.main_collection.settings.color_scheme.label",
      "default": "scheme-1",
      "info": "t:sections.main_collection.settings.color_scheme.info"
    },
    {
      "type": "header",
      "content": "t:sections.main_collection.settings.layout_header.content"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 12,
      "label": "t:sections.main_collection.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "t:sections.main_collection.settings.products_per_row.label"
    },
    {
      "type": "checkbox",
      "id": "show_second_image",
      "label": "t:sections.main_collection.settings.show_second_image.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main_collection.settings.collection_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "t:sections.main_collection.settings.show_collection_image.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "label": "t:sections.main_collection.settings.show_collection_description.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main_collection.settings.filters_header.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.main_collection.settings.filters_paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "t:sections.main_collection.settings.enable_filtering.label",
      "info": "t:sections.main_collection.settings.enable_filtering.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "t:sections.main_collection.settings.enable_sorting.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main_collection.settings.product_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_installments",
      "label": "t:sections.main_collection.settings.show_installments.label",
      "default": true,
      "info": "t:sections.main_collection.settings.show_installments.info"
    }
  ]
}
{% endschema %}
